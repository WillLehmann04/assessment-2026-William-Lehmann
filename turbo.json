{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "init": {
      "cache": false,
      "env": ["DB_HOST", "DB_PORT", "DB_USER", "DB_PASSWORD"]
    },
    "dev": {
      "dependsOn": ["^init"],
      "cache": false,
      "persistent": true,
      "env": ["DB_HOST", "DB_PORT", "DB_USER", "DB_PASSWORD"]
    }
  }
}
